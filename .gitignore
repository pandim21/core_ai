# ── Secrets ────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Distribution / packaging ────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Testing & coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Type checkers & linters ─────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Jupyter ─────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

