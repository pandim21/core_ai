# ---------------------------------------------------------------------------
# AMD Developer Cloud — MI300X inference server
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Base URL for the OpenAI-compatible endpoint served by Ollama on your
# MI300X droplet. Use the droplet's public IP (or hostname) and port 11434.
AMD_API_BASE_URL="http://<YOUR_DROPLET_IP>:11434/v1"

# Ollama does not require a real key, but CrewAI/LiteLLM expects this var
# to be set to something non-empty.
OPENAI_API_KEY="ollama-no-key-needed"

# ---------------------------------------------------------------------------
# Per-role model assignments (Ollama tags). Edit here to swap models without
# touching main_test.py.
# ---------------------------------------------------------------------------
AMD_MODEL_GEO=mixtral:8x22b
AMD_MODEL_ENV=mistral-small
AMD_MODEL_ECON=qwen2.5:72b
AMD_MODEL_COO=llama3.3

# ---------------------------------------------------------------------------
# Optional: per-role endpoint overrides. Uncomment if different models are
# served on separate ports/servers.
# ---------------------------------------------------------------------------
# AMD_API_BASE_URL_GEO=http://localhost:11434/v1
# AMD_API_BASE_URL_ENV=http://localhost:11435/v1
# AMD_API_BASE_URL_ECON=http://localhost:11436/v1
# AMD_API_BASE_URL_COO=http://localhost:11437/v1
